# String hashed (MD5) to produce the 32-char ESP-NOW PMK
PMK_INPUT=my-input-string

# WiFi credentials — used only for OTA HTTP downloads, not normal operation
WIFI_SSID=MyNetwork
WIFI_PASSWORD=MyPassword

# MQTT — optional, leave blank if unused
MQTT_BROKER_IP=
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
